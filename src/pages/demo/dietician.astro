---
import { siteConfig } from "../../config";
import "../../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Personal Dietician - AI-Powered Nutrition and Meal Planning" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>Personal Dietician Demo - {siteConfig.name}</title>
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen" style="background-color: #0a0a0f; color: #f3f4f6;">
    <nav class="border-b border-gray-800 px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-gray-400 hover:text-white transition-colors text-sm flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M5 12l6-6"/><path d="M5 12l6 6"/></svg>
        Back to Portfolio
      </a>
      <div class="flex items-center gap-4">
        <a href="http://34.172.18.199:8080/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-4 py-2 text-white rounded-lg text-sm font-medium transition-all duration-300 hover:opacity-90" style={`background-color: ${siteConfig.accentColor}`}>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-6"/><path d="M11 13l9-9"/><path d="M15 4h5v5"/></svg>
          Open Live App
        </a>
        <a href="https://github.com/ahthakur/dietician-k8s" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors text-sm flex items-center gap-2">
          Source Code
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 00-1.3-3.2 4.2 4.2 0 00-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 00-6.2 0c-2.4-1.6-3.5-1.3-3.5-1.3a4.2 4.2 0 00-.1 3.2 4.6 4.6 0 00-1.3 3.2c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2v3.5"/></svg>
        </a>
      </div>
    </nav>

    <div class="max-w-5xl mx-auto px-6 py-12">
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 11a8.1 8.1 0 00-15.5-2m-.5-4v4h4"/><path d="M4 13a8.1 8.1 0 0015.5 2m.5 4v-4h-4"/></svg>
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold">Personal Dietician</h1>
        </div>
        <p class="text-gray-400 text-lg max-w-2xl">
          AI-powered nutrition tracking and meal planning platform with computer vision food logging, workout-aware scheduling, and real-time macro tracking.
        </p>
        <p class="text-green-500 text-sm mt-3 flex items-center gap-2">
          <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
          Live application — hosted on Google Cloud
        </p>
      </div>

      <!-- Feature Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
          <div class="text-3xl mb-3">📸</div>
          <h3 class="text-lg font-semibold text-gray-200 mb-2">Snap Plate</h3>
          <p class="text-gray-500 text-sm">Take a photo of your meal and AI identifies foods, estimates portion sizes, and calculates macros automatically.</p>
        </div>
        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
          <div class="text-3xl mb-3">🍽️</div>
          <h3 class="text-lg font-semibold text-gray-200 mb-2">AI Meal Ideas</h3>
          <p class="text-gray-500 text-sm">Get personalized meal suggestions based on your remaining daily macros, dietary preferences, and fridge inventory.</p>
        </div>
        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
          <div class="text-3xl mb-3">📊</div>
          <h3 class="text-lg font-semibold text-gray-200 mb-2">Macro Tracking</h3>
          <p class="text-gray-500 text-sm">Real-time tracking of calories, protein, and fiber against personalized daily targets with visual progress rings.</p>
        </div>
        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
          <div class="text-3xl mb-3">🏋️</div>
          <h3 class="text-lg font-semibold text-gray-200 mb-2">Workout-Aware</h3>
          <p class="text-gray-500 text-sm">Adjusts nutrition targets based on your workout schedule. Sees your upcoming sessions and adapts meal recommendations.</p>
        </div>
        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
          <div class="text-3xl mb-3">🛒</div>
          <h3 class="text-lg font-semibold text-gray-200 mb-2">Fridge & Grocery</h3>
          <p class="text-gray-500 text-sm">Scan receipts or snap your fridge to track inventory. Generates smart grocery lists based on planned meals.</p>
        </div>
        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
          <div class="text-3xl mb-3">👥</div>
          <h3 class="text-lg font-semibold text-gray-200 mb-2">Multi-Profile</h3>
          <p class="text-gray-500 text-sm">Supports multiple user profiles with individual macro targets, food logs, and push notifications via ntfy.</p>
        </div>
      </div>

      <!-- Mock App Preview -->
      <h2 class="text-xl font-bold mb-6 text-gray-200">App Preview</h2>
      <div class="max-w-sm mx-auto">
        <div class="bg-gray-900 rounded-2xl border border-gray-800 overflow-hidden shadow-2xl">
          <!-- Status bar mock -->
          <div class="px-5 pt-4 pb-3 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
              <span class="text-lg font-semibold text-gray-100">Dietician</span>
            </div>
            <div class="flex gap-2">
              <span class="px-3 py-1 rounded-full text-sm font-medium text-white" style={`background-color: ${siteConfig.accentColor}`}>Abhijit</span>
              <span class="px-3 py-1 bg-gray-800 rounded-full text-sm font-medium text-gray-400">Mona</span>
            </div>
          </div>

          <!-- Workout banner -->
          <div class="mx-4 mb-4 bg-gray-800 rounded-xl px-4 py-3">
            <p class="text-sm">
              <span class="text-orange-400">🔥 Burn Bootcamp 9:00 AM</span>
              <span class="text-gray-600"> · </span>
              <span class="text-red-400">🥂 Social evening</span>
            </p>
          </div>

          <!-- Macro cards -->
          <div class="grid grid-cols-3 gap-3 px-4 mb-5">
            <div class="bg-gray-800 rounded-xl p-3 text-center border border-gray-700">
              <div class="text-2xl font-bold text-blue-400">847</div>
              <div class="text-xs text-gray-500">/ 1800</div>
              <div class="text-xs text-gray-400 mt-1 font-medium tracking-wide">CALORIES</div>
              <div class="w-full bg-gray-700 rounded-full h-1 mt-2"><div class="h-1 rounded-full bg-blue-400" style="width: 47%"></div></div>
            </div>
            <div class="bg-gray-800 rounded-xl p-3 text-center border border-gray-700">
              <div class="text-2xl font-bold text-green-400">92</div>
              <div class="text-xs text-gray-500">/ 160g</div>
              <div class="text-xs text-gray-400 mt-1 font-medium tracking-wide">PROTEIN</div>
              <div class="w-full bg-gray-700 rounded-full h-1 mt-2"><div class="h-1 rounded-full bg-green-400" style="width: 58%"></div></div>
            </div>
            <div class="bg-gray-800 rounded-xl p-3 text-center border border-gray-700">
              <div class="text-2xl font-bold text-yellow-400">18</div>
              <div class="text-xs text-gray-500">/ 35g</div>
              <div class="text-xs text-gray-400 mt-1 font-medium tracking-wide">FIBER</div>
              <div class="w-full bg-gray-700 rounded-full h-1 mt-2"><div class="h-1 rounded-full bg-yellow-400" style="width: 51%"></div></div>
            </div>
          </div>

          <!-- Input area -->
          <div class="px-4 mb-4">
            <div class="bg-gray-800 rounded-xl px-4 py-3 flex items-center justify-between border border-gray-700">
              <span class="text-gray-500 text-sm">What's on your mind?</span>
              <div class="w-8 h-8 rounded-full flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
              </div>
            </div>
          </div>

          <!-- Action buttons -->
          <div class="grid grid-cols-3 gap-3 px-4 mb-5">
            <div class="bg-gray-800 rounded-xl px-3 py-2.5 text-center border border-gray-700">
              <span class="text-sm text-gray-300">📸 Snap Plate</span>
            </div>
            <div class="bg-gray-800 rounded-xl px-3 py-2.5 text-center border border-gray-700">
              <span class="text-sm text-gray-300">🍽️ Meal Ideas</span>
            </div>
            <div class="bg-gray-800 rounded-xl px-3 py-2.5 text-center border border-gray-700">
              <span class="text-sm text-gray-300">📊 My Stats</span>
            </div>
          </div>

          <!-- Today's log -->
          <div class="px-4 mb-2">
            <h3 class="text-center font-semibold text-gray-200">Today's Log</h3>
            <p class="text-center text-xs text-gray-500 mb-3">3 entries</p>
            <div class="space-y-2 mb-4">
              <div class="bg-gray-800 rounded-lg px-4 py-3 flex justify-between items-center border border-gray-700">
                <div>
                  <p class="text-sm text-gray-200">Greek yogurt with berries</p>
                  <p class="text-xs text-gray-500">8:30 AM</p>
                </div>
                <span class="text-xs text-gray-400">285 cal</span>
              </div>
              <div class="bg-gray-800 rounded-lg px-4 py-3 flex justify-between items-center border border-gray-700">
                <div>
                  <p class="text-sm text-gray-200">Grilled chicken salad</p>
                  <p class="text-xs text-gray-500">12:15 PM</p>
                </div>
                <span class="text-xs text-gray-400">420 cal</span>
              </div>
              <div class="bg-gray-800 rounded-lg px-4 py-3 flex justify-between items-center border border-gray-700">
                <div>
                  <p class="text-sm text-gray-200">Protein shake</p>
                  <p class="text-xs text-gray-500">3:00 PM</p>
                </div>
                <span class="text-xs text-gray-400">142 cal</span>
              </div>
            </div>
          </div>

          <!-- Bottom nav -->
          <div class="border-t border-gray-800 px-4 py-3 flex justify-around">
            <div class="text-center">
              <div class="text-lg">🏠</div>
              <div class="text-xs text-blue-400">Home</div>
            </div>
            <div class="text-center">
              <div class="text-lg">📈</div>
              <div class="text-xs text-gray-500">Analysis</div>
            </div>
            <div class="text-center">
              <div class="text-lg">🧊</div>
              <div class="text-xs text-gray-500">Fridge</div>
            </div>
            <div class="text-center">
              <div class="text-lg">🛒</div>
              <div class="text-xs text-gray-500">Grocery</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Tech Stack -->
      <div class="mt-12 bg-gray-900 rounded-xl border border-gray-800 p-6">
        <h3 class="text-lg font-bold text-gray-200 mb-4">Tech Stack</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 text-sm">
          <div><span class="text-gray-500">Backend:</span> <span class="text-gray-300">Python, FastAPI</span></div>
          <div><span class="text-gray-500">AI:</span> <span class="text-gray-300">Claude Sonnet API</span></div>
          <div><span class="text-gray-500">Database:</span> <span class="text-gray-300">SQLite</span></div>
          <div><span class="text-gray-500">Frontend:</span> <span class="text-gray-300">Vanilla JS</span></div>
          <div><span class="text-gray-500">Deploy:</span> <span class="text-gray-300">Kubernetes (Helm)</span></div>
          <div><span class="text-gray-500">Notifications:</span> <span class="text-gray-300">ntfy</span></div>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-8 text-center">
        <a
          href="http://34.172.18.199:8080/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3 text-white rounded-lg text-base font-medium transition-all duration-300 hover:opacity-90 hover:shadow-lg hover:-translate-y-0.5"
          style={`background-color: ${siteConfig.accentColor}`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-6"/><path d="M11 13l9-9"/><path d="M15 4h5v5"/></svg>
          Try the Live App
        </a>
      </div>
    </div>
  </body>
</html>
