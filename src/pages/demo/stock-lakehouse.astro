---
import { siteConfig } from "../../config";
import "../../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Stock Lakehouse - Trino + Iceberg + Ollama Text-to-SQL Demo" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>Stock Lakehouse Demo - {siteConfig.name}</title>
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen" style="background-color: #0a0a0f; color: #f3f4f6;">
    <nav class="border-b border-gray-800 px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-gray-400 hover:text-white transition-colors text-sm flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M5 12l6-6"/><path d="M5 12l6 6"/></svg>
        Back to Portfolio
      </a>
      <a href="https://github.com/ahthakur/stock-lakehouse" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors text-sm flex items-center gap-2">
        View Source
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 00-1.3-3.2 4.2 4.2 0 00-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 00-6.2 0c-2.4-1.6-3.5-1.3-3.5-1.3a4.2 4.2 0 00-.1 3.2 4.6 4.6 0 00-1.3 3.2c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2v3.5"/></svg>
      </a>
    </nav>

    <div class="max-w-5xl mx-auto px-6 py-12">
      <!-- Header -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg flex items-center justify-center" style={`background-color: ${siteConfig.accentColor}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg>
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold">Stock Lakehouse</h1>
        </div>
        <p class="text-gray-400 text-lg max-w-2xl">
          Explore decades of daily US stock-market history through a modern lakehouse stack. Ask questions in plain English and watch a local AI model write live SQL.
        </p>
        <p class="text-yellow-500 text-sm mt-3 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v.01"/><path d="M12 8v4"/></svg>
          Interactive demo with simulated data
        </p>
      </div>

      <!-- Section nav -->
      <div class="flex flex-wrap gap-2 mb-10">
        <a href="#architecture" class="px-4 py-2 bg-gray-800 text-gray-300 rounded-lg text-sm hover:bg-gray-700 transition-colors">1. Architecture</a>
        <a href="#pipeline" class="px-4 py-2 bg-gray-800 text-gray-300 rounded-lg text-sm hover:bg-gray-700 transition-colors">2. Data Pipeline</a>
        <a href="#text-to-sql" class="px-4 py-2 bg-gray-800 text-gray-300 rounded-lg text-sm hover:bg-gray-700 transition-colors">3. Text-to-SQL</a>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- SECTION 1: ARCHITECTURE                     -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="architecture" class="mb-16">
        <h2 class="text-xl font-bold mb-6 text-gray-200 flex items-center gap-2">
          <span class="text-sm px-2 py-0.5 rounded bg-blue-500/20 text-blue-400">Stack</span>
          Architecture
        </h2>

        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6 mb-6" style="background-color: #111827;">
          <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wide mb-4">Platform Mapping</h3>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-gray-700">
                  <th class="text-left py-2 pr-4 text-gray-400 font-medium">Component</th>
                  <th class="text-left py-2 text-gray-400 font-medium">Role</th>
                </tr>
              </thead>
              <tbody class="font-mono text-gray-300">
                <tr class="border-b border-gray-800"><td class="py-2.5 pr-4 text-cyan-400">Postgres</td><td class="py-2.5 text-gray-400">Operational source database</td></tr>
                <tr class="border-b border-gray-800"><td class="py-2.5 pr-4 text-cyan-400">Trino</td><td class="py-2.5 text-gray-400">Federated SQL engine</td></tr>
                <tr class="border-b border-gray-800"><td class="py-2.5 pr-4 text-cyan-400">MinIO</td><td class="py-2.5 text-gray-400">S3-compatible object storage</td></tr>
                <tr class="border-b border-gray-800"><td class="py-2.5 pr-4 text-cyan-400">Apache Iceberg</td><td class="py-2.5 text-gray-400">Open table format with time travel</td></tr>
                <tr class="border-b border-gray-800"><td class="py-2.5 pr-4 text-cyan-400">Iceberg REST Catalog</td><td class="py-2.5 text-gray-400">Table versioning and governance</td></tr>
                <tr class="border-b border-gray-800"><td class="py-2.5 pr-4 text-cyan-400">Ollama + Llama 3.2</td><td class="py-2.5 text-gray-400">Local AI text-to-SQL layer</td></tr>
                <tr><td class="py-2.5 pr-4 text-cyan-400">FastAPI</td><td class="py-2.5 text-gray-400">Web UI and API</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6" style="background-color: #111827;">
          <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wide mb-4">Data Flow</h3>
          <div class="font-mono text-sm text-gray-400 leading-loose">
            <p>Daily Prices (3.3M rows, 614 tickers)</p>
            <p class="text-gray-600 ml-8">|</p>
            <p class="ml-8"><span class="text-gray-600">v</span></p>
            <p class="ml-4"><span class="text-cyan-400">Postgres</span> <span class="text-gray-600">(COPY from CSV)</span></p>
            <p class="text-gray-600 ml-8">|</p>
            <p class="ml-4"><span class="text-orange-400">Trino</span> <span class="text-gray-600">federates via CTAS</span></p>
            <p class="text-gray-600 ml-8">|</p>
            <p class="ml-8"><span class="text-gray-600">+--></span> <span class="text-yellow-400">Bronze</span> <span class="text-gray-600">(raw Parquet on MinIO)</span></p>
            <p class="ml-8"><span class="text-gray-600">+--></span> <span class="text-blue-400">Silver</span> <span class="text-gray-600">(cleaned, partitioned by year, daily returns)</span></p>
            <p class="ml-8"><span class="text-gray-600">+--></span> <span class="text-green-400">Gold</span> <span class="text-gray-600">(annual returns, volatility, drawdowns, streaks)</span></p>
            <p class="text-gray-600 ml-8">|</p>
            <p class="ml-4"><span class="text-purple-400">Ollama</span> <span class="text-gray-600">writes SQL from questions, Trino executes, model summarizes</span></p>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- SECTION 2: DATA PIPELINE                    -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="pipeline" class="mb-16">
        <h2 class="text-xl font-bold mb-6 text-gray-200 flex items-center gap-2">
          <span class="text-sm px-2 py-0.5 rounded bg-green-500/20 text-green-400">Medallion</span>
          Data Pipeline
        </h2>

        <div class="mb-6 flex gap-3">
          <button id="run-pipeline" class="px-5 py-2.5 text-white rounded-lg text-sm font-medium transition-all duration-300 hover:opacity-90 hover:shadow-lg flex items-center gap-2" style={`background-color: ${siteConfig.accentColor}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4v16l13-8z"/></svg>
            Run Pipeline
          </button>
          <button id="reset-pipeline" class="px-5 py-2.5 bg-gray-800 text-gray-300 rounded-lg text-sm font-medium transition-all duration-300 hover:bg-gray-700 hidden items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 11A8.1 8.1 0 004.5 9M4 5v4h4"/><path d="M4 13a8.1 8.1 0 0015.5 2m.5 4v-4h-4"/></svg>
            Reset
          </button>
        </div>

        <!-- Pipeline Terminal -->
        <div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden mb-8" style="background-color: #111827;">
          <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-800">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <span class="text-gray-500 text-xs ml-2">stock-lakehouse — pipeline</span>
          </div>
          <div id="pipeline-terminal" class="p-5 font-mono text-sm leading-relaxed h-[400px] overflow-y-auto">
            <p class="text-gray-500">$ ./run.sh data/full_prices.csv data/full_tickers.csv</p>
            <p class="text-gray-500 mt-1">Press "Run Pipeline" to start...</p>
          </div>
        </div>

        <!-- Row counts dashboard -->
        <div id="pipeline-dashboard" class="hidden">
          <h3 class="text-lg font-bold mb-4 text-gray-200">Lakehouse Tables</h3>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
            <div class="bg-gray-900 rounded-xl border border-gray-800 p-5 text-center" style="background-color: #111827;">
              <div class="text-2xl font-bold text-yellow-400">3.3M</div>
              <div class="text-xs text-gray-500 mt-1 uppercase tracking-wide">Bronze Prices</div>
            </div>
            <div class="bg-gray-900 rounded-xl border border-gray-800 p-5 text-center" style="background-color: #111827;">
              <div class="text-2xl font-bold text-blue-400">3.3M</div>
              <div class="text-xs text-gray-500 mt-1 uppercase tracking-wide">Silver Prices</div>
              <div class="text-xs text-gray-600 mt-0.5">27 partitions</div>
            </div>
            <div class="bg-gray-900 rounded-xl border border-gray-800 p-5 text-center" style="background-color: #111827;">
              <div class="text-2xl font-bold text-green-400">13.6K</div>
              <div class="text-xs text-gray-500 mt-1 uppercase tracking-wide">Gold Analytics</div>
            </div>
            <div class="bg-gray-900 rounded-xl border border-gray-800 p-5 text-center" style="background-color: #111827;">
              <div class="text-2xl font-bold text-purple-400">614</div>
              <div class="text-xs text-gray-500 mt-1 uppercase tracking-wide">Tickers</div>
            </div>
          </div>

          <div class="bg-gray-900 rounded-xl border border-gray-800 p-6" style="background-color: #111827;">
            <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wide mb-4">Gold Layer Products</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
              <div class="flex items-start gap-3">
                <span class="text-green-400 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg>
                </span>
                <div>
                  <p class="text-gray-200 font-medium">Annual Returns</p>
                  <p class="text-gray-500 text-xs">First-to-last close per ticker per year</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-orange-400 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l3-9 4 18 3-9h4"/></svg>
                </span>
                <div>
                  <p class="text-gray-200 font-medium">Volatility</p>
                  <p class="text-gray-500 text-xs">Annualized stddev of daily returns * sqrt(252)</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-red-400 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 16l4-4 4 4 4-4"/></svg>
                </span>
                <div>
                  <p class="text-gray-200 font-medium">Max Drawdown</p>
                  <p class="text-gray-500 text-xs">Worst peak-to-trough per ticker per year</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-blue-400 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 3l0 7l6 0l-8 11l0-7l-6 0l8-11"/></svg>
                </span>
                <div>
                  <p class="text-gray-200 font-medium">Up Streaks</p>
                  <p class="text-gray-500 text-xs">Longest consecutive up days per ticker</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══════════════════════════════════════════ -->
      <!-- SECTION 3: TEXT-TO-SQL                       -->
      <!-- ═══════════════════════════════════════════ -->
      <div id="text-to-sql" class="mb-16">
        <h2 class="text-xl font-bold mb-2 text-gray-200 flex items-center gap-2">
          <span class="text-sm px-2 py-0.5 rounded bg-purple-500/20 text-purple-400">AI</span>
          Text-to-SQL
        </h2>
        <p class="text-gray-500 text-sm mb-6">
          Type a question in plain English. The local Ollama model writes Trino SQL, the query runs live against Iceberg tables on MinIO, and the model summarizes the result.
        </p>

        <!-- Sample queries -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
          <button class="query-btn px-4 py-3 bg-gray-800 border border-gray-700 text-gray-300 rounded-lg text-sm text-left hover:border-blue-500/50 hover:bg-gray-800/80 transition-all" data-q="Which stocks gained most in 2024?">
            <span class="text-gray-500 text-xs block mb-1">Top Gainers</span>
            Which stocks gained most in 2024?
          </button>
          <button class="query-btn px-4 py-3 bg-gray-800 border border-gray-700 text-gray-300 rounded-lg text-sm text-left hover:border-blue-500/50 hover:bg-gray-800/80 transition-all" data-q="Which sector was most volatile in 2022?">
            <span class="text-gray-500 text-xs block mb-1">Sector Volatility</span>
            Which sector was most volatile in 2022?
          </button>
          <button class="query-btn px-4 py-3 bg-gray-800 border border-gray-700 text-gray-300 rounded-lg text-sm text-left hover:border-blue-500/50 hover:bg-gray-800/80 transition-all" data-q="What was the worst drawdown in 2020 by sector?">
            <span class="text-gray-500 text-xs block mb-1">2020 Crash</span>
            What was the worst drawdown in 2020 by sector?
          </button>
        </div>

        <!-- Query simulation -->
        <div id="query-result" class="hidden">
          <div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden mb-6" style="background-color: #111827;">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-gray-800">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
              <span class="text-gray-500 text-xs ml-2">stock-lakehouse — text-to-sql</span>
            </div>
            <div id="query-terminal" class="p-5 font-mono text-sm leading-relaxed h-[320px] overflow-y-auto"></div>
          </div>

          <!-- Result table -->
          <div id="result-table" class="hidden bg-gray-900 rounded-xl border border-gray-800 overflow-auto mb-6" style="background-color: #111827;">
            <div class="px-5 py-3 border-b border-gray-800">
              <span class="text-gray-300 text-sm font-medium">Query Result</span>
              <span id="result-time" class="text-gray-500 text-xs ml-2"></span>
            </div>
            <div class="overflow-x-auto">
              <table id="result-data" class="w-full text-sm">
                <thead id="result-head" class="border-b border-gray-700"></thead>
                <tbody id="result-body"></tbody>
              </table>
            </div>
          </div>

          <!-- Answer -->
          <div id="result-answer" class="hidden bg-gray-800/50 border-l-3 border-green-500 p-4 rounded-r-xl text-gray-200 text-sm" style="border-left: 3px solid #22c55e;"></div>
        </div>

        <!-- How it works -->
        <div class="bg-gray-900 rounded-xl border border-gray-800 p-6 mt-6" style="background-color: #111827;">
          <h3 class="text-sm font-bold text-gray-400 uppercase tracking-wide mb-4">How It Works</h3>
          <div class="flex flex-wrap items-center gap-3 text-sm">
            <div class="flex items-center gap-2 px-3 py-2 bg-gray-800 rounded-lg">
              <span class="text-purple-400">1.</span>
              <span class="text-gray-300">Question + schema prompt</span>
            </div>
            <span class="text-gray-600">&rarr;</span>
            <div class="flex items-center gap-2 px-3 py-2 bg-gray-800 rounded-lg">
              <span class="text-blue-400">2.</span>
              <span class="text-gray-300">Ollama writes SQL</span>
            </div>
            <span class="text-gray-600">&rarr;</span>
            <div class="flex items-center gap-2 px-3 py-2 bg-gray-800 rounded-lg">
              <span class="text-cyan-400">3.</span>
              <span class="text-gray-300">Trino executes on Iceberg</span>
            </div>
            <span class="text-gray-600">&rarr;</span>
            <div class="flex items-center gap-2 px-3 py-2 bg-gray-800 rounded-lg">
              <span class="text-green-400">4.</span>
              <span class="text-gray-300">Model summarizes result</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      const pipeTerminal = document.getElementById('pipeline-terminal')!;
      const pipeRunBtn = document.getElementById('run-pipeline')!;
      const pipeResetBtn = document.getElementById('reset-pipeline')!;
      const pipeDashboard = document.getElementById('pipeline-dashboard')!;
      const queryResult = document.getElementById('query-result')!;
      const queryTerminal = document.getElementById('query-terminal')!;
      const resultTable = document.getElementById('result-table')!;
      const resultHead = document.getElementById('result-head')!;
      const resultBody = document.getElementById('result-body')!;
      const resultTime = document.getElementById('result-time')!;
      const resultAnswer = document.getElementById('result-answer')!;

      interface Line { text: string; delay: number; cls?: string }

      const pipelineLines: Line[] = [
        { text: '', delay: 300 },
        { text: '==============================================================', delay: 100, cls: 'text-blue-400' },
        { text: ' Stock Lakehouse: Trino + Iceberg + MinIO + Ollama + web UI', delay: 100, cls: 'text-blue-400' },
        { text: '==============================================================', delay: 400, cls: 'text-blue-400' },
        { text: '', delay: 200 },
        { text: '[1/5] Building the app image and starting containers ...', delay: 600, cls: 'text-cyan-400' },
        { text: '  Container sl-minio        Started', delay: 200, cls: 'text-gray-400' },
        { text: '  Container sl-postgres      Started', delay: 150, cls: 'text-gray-400' },
        { text: '  Container sl-iceberg-rest  Started', delay: 150, cls: 'text-gray-400' },
        { text: '  Container sl-trino         Started', delay: 150, cls: 'text-gray-400' },
        { text: '  Container sl-app           Started', delay: 200, cls: 'text-green-400' },
        { text: '', delay: 200 },
        { text: '[2/5] Waiting for Trino (first boot can take ~60s) ...', delay: 400, cls: 'text-cyan-400' },
        { text: '  .... ready.', delay: 600, cls: 'text-green-400' },
        { text: '', delay: 200 },
        { text: '[3/5] Pulling the Ollama model ...', delay: 400, cls: 'text-cyan-400' },
        { text: '  pulling llama3.2:1b ........................... done', delay: 500, cls: 'text-gray-400' },
        { text: '', delay: 200 },
        { text: '[4/5] Loading data into Postgres ...', delay: 400, cls: 'text-cyan-400' },
        { text: '  >>> Loading tickers (614 rows) ...', delay: 300, cls: 'text-gray-400' },
        { text: '  COPY 614', delay: 200, cls: 'text-green-400' },
        { text: '  >>> Loading prices (3,305,400 rows) ...', delay: 300, cls: 'text-gray-400' },
        { text: '  COPY 3305400', delay: 600, cls: 'text-green-400' },
        { text: '', delay: 200 },
        { text: '[5/5] Building bronze, silver, and gold Iceberg tables ...', delay: 400, cls: 'text-cyan-400' },
        { text: '  Bronze: CREATE TABLE bronze.prices (3,305,400 rows)', delay: 400, cls: 'text-yellow-400' },
        { text: '  Bronze: CREATE TABLE bronze.tickers (614 rows)', delay: 200, cls: 'text-yellow-400' },
        { text: '  Silver: CREATE TABLE silver.prices (3,305,400 rows)', delay: 500, cls: 'text-blue-400' },
        { text: '          partitioned by year, sorted by ticker', delay: 200, cls: 'text-gray-500' },
        { text: '  Silver: CREATE TABLE silver.tickers (614 rows)', delay: 200, cls: 'text-blue-400' },
        { text: '  Gold: CREATE TABLE annual_returns (13,592 rows)', delay: 300, cls: 'text-green-400' },
        { text: '  Gold: CREATE TABLE volatility (13,592 rows)', delay: 200, cls: 'text-green-400' },
        { text: '  Gold: CREATE TABLE drawdown_by_year (13,592 rows)', delay: 200, cls: 'text-green-400' },
        { text: '  Gold: CREATE TABLE up_streaks (614 rows)', delay: 200, cls: 'text-green-400' },
        { text: '', delay: 300 },
        { text: '==============================================================', delay: 100, cls: 'text-blue-400' },
        { text: '  Ready.', delay: 100, cls: 'text-white' },
