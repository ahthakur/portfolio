      let pipeRunning = false;
      let queryRunning = false;

      async function animateTerminal(el: HTMLElement, lines: Line[]) {
        for (const line of lines) {
          await new Promise(r => setTimeout(r, line.delay));
          const p = document.createElement('p');
          p.textContent = line.text || ' ';
          if (line.cls) p.className = line.cls;
          el.appendChild(p);
          el.scrollTop = el.scrollHeight;
        }
      }

      pipeRunBtn.addEventListener('click', async () => {
        if (pipeRunning) return;
        pipeRunning = true;
        pipeRunBtn.classList.add('opacity-50', 'pointer-events-none');
        pipeTerminal.innerHTML = '<p class="text-gray-500">$ ./run.sh data/full_prices.csv data/full_tickers.csv</p>';
        pipeDashboard.classList.add('hidden');
        await animateTerminal(pipeTerminal, pipelineLines);
        await new Promise(r => setTimeout(r, 500));
        pipeDashboard.classList.remove('hidden');
        pipeDashboard.scrollIntoView({ behavior: 'smooth', block: 'start' });
        pipeResetBtn.classList.remove('hidden');
        pipeRunning = false;
      });

      pipeResetBtn.addEventListener('click', () => {
        pipeTerminal.innerHTML = '<p class="text-gray-500">$ ./run.sh data/full_prices.csv data/full_tickers.csv</p><p class="text-gray-500 mt-1">Press "Run Pipeline" to start...</p>';
        pipeDashboard.classList.add('hidden');
        pipeResetBtn.classList.add('hidden');
        pipeRunBtn.classList.remove('opacity-50', 'pointer-events-none');
      });

      document.querySelectorAll('.query-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const q = (btn as HTMLElement).dataset.q!;
          const sim = queries[q];
          if (!sim || queryRunning) return;
          queryRunning = true;

          document.querySelectorAll('.query-btn').forEach(b => b.classList.add('opacity-50', 'pointer-events-none'));

          queryResult.classList.remove('hidden');
          resultTable.classList.add('hidden');
          resultAnswer.classList.add('hidden');
          queryTerminal.innerHTML = '';

          queryResult.scrollIntoView({ behavior: 'smooth', block: 'start' });
          await animateTerminal(queryTerminal, sim.lines);

          await new Promise(r => setTimeout(r, 400));

          resultHead.innerHTML = '<tr class="border-b border-gray-700">' + sim.columns.map(c => `<th class="text-left py-2 px-4 text-gray-400 font-medium text-sm">${c}</th>`).join('') + '</tr>';
          resultBody.innerHTML = sim.rows.map(row =>
            '<tr class="border-b border-gray-800">' + row.map(v => `<td class="py-2.5 px-4 text-gray-300 text-sm font-mono">${v}</td>`).join('') + '</tr>'
          ).join('');
          resultTime.textContent = '(0.34s)';
          resultTable.classList.remove('hidden');

          await new Promise(r => setTimeout(r, 600));
          resultAnswer.textContent = sim.answer;
          resultAnswer.classList.remove('hidden');

          document.querySelectorAll('.query-btn').forEach(b => b.classList.remove('opacity-50', 'pointer-events-none'));
          queryRunning = false;
        });
      });
    </script>
  </body>
</html>
