---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold" style="color: #ccd6f6">
              Projects
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-8">
              {siteConfig.projects.map((project, index) => (
                <div class="group relative">
                  <div
                    class="project-card block relative p-4 sm:p-6 md:p-8 rounded-xl sm:rounded-2xl transition-all duration-300 hover:-translate-y-1"
                  >
                    <div class="space-y-4">
                      <div>
                        <span
                          class="text-sm font-mono"
                          style={{ color: siteConfig.accentColor }}
                        >
                          0{index + 1}
                        </span>
                        <h3 class="text-xl sm:text-2xl font-bold mt-1" style="color: #ccd6f6">
                          {project.name}
                        </h3>
                      </div>

                      {/* Project preview */}
                      {["Personal Dietician", "DrinkFinder"].includes(project.name) ? (
                        <div class="mini-preview rounded-lg overflow-hidden border" style="background-color: #0d1117; border-color: #1e2d3d;">
                          <div class="flex items-center gap-1.5 px-3 py-1.5 border-b" style="border-color: #1e2d3d;">
                            <div class="w-2 h-2 rounded-full" style="background-color: #ff5f57;"></div>
                            <div class="w-2 h-2 rounded-full" style="background-color: #febc2e;"></div>
                            <div class="w-2 h-2 rounded-full" style="background-color: #28c840;"></div>
                            <span class="text-[10px] ml-1.5" style="color: #4a5568;">
                              {project.name === "Personal Dietician" ? "dietician.abhijitt.com" : "drinkfinder.vercel.app"}
                            </span>
                          </div>
                          <div
                            class="preview-body overflow-hidden"
                            style="height: 190px; padding: 8px;"
                            data-project={project.name}
                          ></div>
                        </div>
                      ) : (
                        <div class="mini-terminal rounded-lg overflow-hidden border" style="background-color: #0d1117; border-color: #1e2d3d;">
                          <div class="flex items-center gap-1.5 px-3 py-1.5 border-b" style="border-color: #1e2d3d;">
                            <div class="w-2 h-2 rounded-full" style="background-color: #ff5f57;"></div>
                            <div class="w-2 h-2 rounded-full" style="background-color: #febc2e;"></div>
                            <div class="w-2 h-2 rounded-full" style="background-color: #28c840;"></div>
                            <span class="text-[10px] ml-1.5" style="color: #4a5568;" data-terminal-title={project.name}></span>
                          </div>
                          <div
                            class="terminal-body px-3 py-2 font-mono text-xs leading-[1.6] h-[140px] overflow-hidden"
                            data-project={project.name}
                          ></div>
                        </div>
                      )}

                      <p class="text-base sm:text-lg leading-relaxed" style="color: #8892b0">
                        {project.description}
                      </p>

                      {project.skills && project.skills.length > 0 && (
                        <div class="flex flex-wrap gap-1.5 sm:gap-2 pt-2">
                          {project.skills.map((skill) => (
                            <span class="px-2.5 sm:px-3 py-1 sm:py-1.5 rounded-md sm:rounded-lg text-xs sm:text-sm font-mono" style="color: #8892b0; background-color: rgba(29, 78, 216, 0.1)">
                              {skill}
                            </span>
                          ))}
                        </div>
                      )}

                      <div class="flex flex-wrap gap-3 pt-3">
                        {project.demo && (
                          <a
                            href={project.demo}
                            class="demo-btn inline-flex items-center gap-2 px-5 py-2.5 text-white rounded-lg text-sm font-medium transition-all duration-300"
                            style={`background-color: ${siteConfig.accentColor}`}
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                              <path d="M7 4v16l13 -8z" />
                            </svg>
                            Live Demo
                          </a>
                        )}
                        {project.link && (
                          <a
                            href={project.link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="source-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-all duration-300"
                          >
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                              <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
                            </svg>
                            Source Code
                          </a>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .project-card {
    background-color: rgba(17, 34, 64, 0.6);
    border: 1px solid #233554;
  }

  .project-card:hover {
    background-color: rgba(17, 34, 64, 0.9);
    border-color: rgba(29, 78, 216, 0.3);
    box-shadow: 0 10px 30px -15px rgba(2, 12, 27, 0.7),
                inset 0 1px 0 rgba(29, 78, 216, 0.1);
  }

  .demo-btn:hover {
    box-shadow: 0 0 20px rgba(29, 78, 216, 0.4);
  }

  .source-btn {
    color: #ccd6f6;
    border: 1px solid #233554;
    background-color: transparent;
  }

  .source-btn:hover {
    border-color: rgba(29, 78, 216, 0.5);
    color: white;
    background-color: rgba(29, 78, 216, 0.1);
  }

  .mini-terminal {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .mini-terminal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .mini-preview {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .mini-preview.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
</style>

<script>
  interface TermLine {
    text: string;
    color: string;
    delay: number;
  }

  const wait = (ms: number) => new Promise(r => setTimeout(r, ms));

  const terminalAnimations: Record<string, { title: string; lines: TermLine[] }> = {
    "ComplianceGuard": {
      title: "complianceguard — scan",
      lines: [
        { text: "$ python3 -m agent.main --policy pci-dss-v4.yaml", color: "#6b7280", delay: 400 },
        { text: "", color: "", delay: 200 },
        { text: "[1/5] Scanning containers ...", color: "#22d3ee", delay: 500 },
        { text: "  web-app   api-gateway   db", color: "#6b7280", delay: 300 },
        { text: "[2/5] Evaluating 10 policies ...", color: "#22d3ee", delay: 500 },
        { text: "[3/5] Classifying with Claude AI ...", color: "#a78bfa", delay: 600 },
        { text: "", color: "", delay: 200 },
        { text: "  CRITICAL  2   root user, plaintext secrets", color: "#ef4444", delay: 300 },
        { text: "  HIGH      3   no TLS, no limits, unpin image", color: "#f97316", delay: 300 },
        { text: "  MEDIUM    1   missing health check", color: "#eab308", delay: 300 },
        { text: "  PASS      4", color: "#22c55e", delay: 300 },
        { text: "", color: "", delay: 200 },
        { text: "[4/5] Report: reports/_LastReport/", color: "#22d3ee", delay: 400 },
        { text: "[5/5] Compliance score: 40%", color: "#ef4444", delay: 400 },
      ],
    },
    "Stock Lakehouse": {
      title: "stock-lakehouse — text-to-sql",
      lines: [
        { text: "Question: Which stocks gained most in 2024?", color: "#ccd6f6", delay: 400 },
        { text: "", color: "", delay: 200 },
        { text: "Generating SQL with Ollama (llama3.2:1b) ...", color: "#a78bfa", delay: 600 },
        { text: "SELECT ticker, company_name,", color: "#22d3ee", delay: 200 },
        { text: "  round(annual_return*100,1) AS pct", color: "#22d3ee", delay: 200 },
        { text: "FROM iceberg.gold.annual_returns", color: "#22d3ee", delay: 200 },
        { text: "WHERE year = 2024", color: "#22d3ee", delay: 200 },
        { text: "ORDER BY annual_return DESC LIMIT 5", color: "#22d3ee", delay: 200 },
        { text: "", color: "", delay: 200 },
        { text: "Executing on Trino ... (0.34s)", color: "#f97316", delay: 500 },
        { text: "  RGTI                        1551.5%", color: "#4ade80", delay: 250 },
        { text: "  APP    AppLovin              735.0%", color: "#4ade80", delay: 250 },
        { text: "  LUNR   Intuitive Machines    669.5%", color: "#4ade80", delay: 250 },
        { text: "  RKLB   Rocket Lab            379.7%", color: "#4ade80", delay: 250 },
        { text: "  PLTR   Palantir              356.2%", color: "#4ade80", delay: 250 },
      ],
    },
  };

  function createLine(text: string, color: string): HTMLParagraphElement {
    const p = document.createElement('p');
    if (text === '') {
      p.innerHTML = '&nbsp;';
    } else {
      p.textContent = text;
    }
    if (color) p.style.color = color;
    p.style.margin = '0';
    p.style.whiteSpace = 'pre';
    return p;
  }

  async function runTerminalAnimation(el: HTMLElement, lines: TermLine[]) {
    el.innerHTML = '';
    for (const line of lines) {
      await wait(line.delay);
      el.appendChild(createLine(line.text, line.color));
      el.scrollTop = el.scrollHeight;
    }
  }

  async function loopTerminalAnimation(el: HTMLElement, lines: TermLine[]) {
    while (true) {
      await runTerminalAnimation(el, lines);
      await wait(3000);
    }
  }

  function el(tag: string, styles: string, text?: string): HTMLElement {
    const node = document.createElement(tag);
    node.style.cssText = styles;
    if (text) node.textContent = text;
    return node;
  }

  async function buildDieticianMockup(container: HTMLElement) {
    container.innerHTML = '';

    const header = el('div', 'display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;opacity:0;transition:opacity 0.3s');
    header.appendChild(el('span', 'color:#f3f4f6;font-weight:600;font-size:11px', 'Dietician'));
    header.appendChild(el('span', 'background:#1d4ed8;color:white;padding:1px 8px;border-radius:10px;font-size:9px', 'Abhijit'));
    container.appendChild(header);
    await wait(300);
    header.style.opacity = '1';

    await wait(300);
    const banner = el('div', 'background:#1a1a2e;border-radius:6px;padding:4px 8px;margin-bottom:8px;font-size:9px;opacity:0;transition:opacity 0.3s');
    banner.appendChild(el('span', 'color:#fb923c', 'Burn Bootcamp 9AM'));
    banner.appendChild(el('span', 'color:#4a5568', ' · '));
    banner.appendChild(el('span', 'color:#f87171', 'Social PM'));
    container.appendChild(banner);
    await wait(200);
    banner.style.opacity = '1';

    await wait(300);
    const macroData = [
      { label: 'CALORIES', value: '847', max: '1800', pct: 47, color: '#60a5fa' },
      { label: 'PROTEIN', value: '92g', max: '160g', pct: 58, color: '#4ade80' },
      { label: 'FIBER', value: '18g', max: '35g', pct: 51, color: '#facc15' },
    ];
    const macros = el('div', 'display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px;margin-bottom:8px');
    const cards: HTMLElement[] = [];
    const bars: HTMLElement[] = [];

    for (const m of macroData) {
      const card = el('div', 'background:#1a1a2e;border-radius:6px;padding:5px 3px;text-align:center;border:1px solid #2d3748;opacity:0;transition:opacity 0.3s');
      card.appendChild(el('div', `font-size:14px;font-weight:700;color:${m.color}`, m.value));
      card.appendChild(el('div', 'font-size:7px;color:#6b7280', '/ ' + m.max));
      card.appendChild(el('div', 'font-size:7px;color:#8892b0;margin-top:2px;letter-spacing:0.5px', m.label));
      const track = el('div', 'background:#374151;border-radius:2px;height:2px;margin-top:3px;overflow:hidden');
      const bar = el('div', `height:2px;border-radius:2px;background:${m.color};width:0%;transition:width 0.8s ease-out`);
      track.appendChild(bar);
      card.appendChild(track);
      macros.appendChild(card);
      cards.push(card);
      bars.push(bar);
    }
    container.appendChild(macros);

    for (let i = 0; i < cards.length; i++) {
      await wait(150);
      cards[i].style.opacity = '1';
    }
    await wait(200);
    for (let i = 0; i < bars.length; i++) {
      bars[i].style.width = macroData[i].pct + '%';
      await wait(150);
    }

    await wait(400);
    const logTitle = el('div', 'color:#e2e8f0;font-size:9px;font-weight:600;margin-bottom:4px;opacity:0;transition:opacity 0.3s', "Today's Log");
    container.appendChild(logTitle);
    await wait(200);
    logTitle.style.opacity = '1';

    const entries = [
      { food: 'Greek yogurt + berries', time: '8:30 AM', cal: '285 cal' },
      { food: 'Grilled chicken salad', time: '12:15 PM', cal: '420 cal' },
      { food: 'Protein shake', time: '3:00 PM', cal: '142 cal' },
    ];

    for (const e of entries) {
      await wait(250);
      const row = el('div', 'display:flex;justify-content:space-between;align-items:center;background:#1a1a2e;border-radius:4px;padding:3px 6px;margin-bottom:3px;border:1px solid #2d3748;opacity:0;transform:translateY(4px);transition:opacity 0.3s,transform 0.3s');
      const left = el('div', '');
      left.appendChild(el('div', 'color:#e2e8f0;font-size:9px', e.food));
      left.appendChild(el('div', 'color:#6b7280;font-size:7px', e.time));
      row.appendChild(left);
      row.appendChild(el('span', 'color:#8892b0;font-size:8px', e.cal));
      container.appendChild(row);
      await wait(50);
      row.style.opacity = '1';
      row.style.transform = 'translateY(0)';
    }
  }

  async function buildDrinkFinderMockup(container: HTMLElement) {
    container.innerHTML = '';

    const searchBar = el('div', 'background:#112240;border:1px solid #233554;border-radius:6px;padding:6px 10px;margin-bottom:8px;display:flex;align-items:center;gap:6px');
    searchBar.appendChild(el('span', 'color:#4a5568;font-size:12px', '🔍'));
    const searchText = el('span', 'color:#ccd6f6;font-size:11px');
    searchBar.appendChild(searchText);
    const cursor = el('span', 'color:#1d4ed8;animation:blink 0.8s infinite', '|');
    searchBar.appendChild(cursor);
    container.appendChild(searchBar);

    const query = "Tito's Vodka 750ml";
    for (const char of query) {
      await wait(50);
      searchText.textContent += char;
    }
    cursor.remove();

    await wait(400);
    const status = el('div', 'color:#8892b0;font-size:9px;margin-bottom:6px;opacity:0;transition:opacity 0.3s', 'Comparing 4 stores near you...');
    container.appendChild(status);
    await wait(100);
    status.style.opacity = '1';

    await wait(600);
    status.textContent = '4 results found';

    const results = [
      { store: 'Total Wine', price: '$19.99', best: true, dist: '0.3 mi' },
      { store: 'ABC Fine Wine', price: '$22.49', best: false, dist: '1.2 mi' },
      { store: 'Publix', price: '$24.99', best: false, dist: '0.8 mi' },
      { store: 'CVS', price: '$27.99', best: false, dist: '1.5 mi' },
    ];

    for (const r of results) {
      await wait(200);
      const row = el('div', `display:flex;justify-content:space-between;align-items:center;background:#112240;border:1px solid ${r.best ? '#065f46' : '#233554'};border-radius:6px;padding:5px 10px;margin-bottom:4px;opacity:0;transform:translateX(-8px);transition:opacity 0.3s,transform 0.3s`);
      const left = el('div', '');
      left.appendChild(el('div', 'color:#ccd6f6;font-size:10px', r.store));
      left.appendChild(el('div', 'color:#6b7280;font-size:7px', r.dist));
      row.appendChild(left);
      const right = el('div', 'display:flex;align-items:center;gap:6px');
      if (r.best) right.appendChild(el('span', 'background:#065f46;color:#4ade80;padding:1px 6px;border-radius:4px;font-size:7px;font-weight:600', 'BEST'));
      right.appendChild(el('span', `color:${r.best ? '#4ade80' : '#8892b0'};font-size:11px;font-weight:${r.best ? '700' : '400'}`, r.price));
      row.appendChild(right);
      container.appendChild(row);
      await wait(50);
      row.style.opacity = '1';
      row.style.transform = 'translateX(0)';
    }

    await wait(400);
    const savings = el('div', 'text-align:center;margin-top:2px;opacity:0;transition:opacity 0.4s');
    savings.appendChild(el('span', 'color:#4ade80;font-size:10px;font-weight:600', 'Save $8.00 '));
    savings.appendChild(el('span', 'color:#6b7280;font-size:9px', 'at Total Wine'));
    container.appendChild(savings);
    await wait(100);
    savings.style.opacity = '1';
  }

  async function loopUIMockup(container: HTMLElement, builder: (el: HTMLElement) => Promise<void>) {
    while (true) {
      await builder(container);
      await wait(3000);
    }
  }

  const terminalObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const terminal = entry.target as HTMLElement;
      const wrapper = terminal.closest('.mini-terminal') as HTMLElement;
      if (entry.isIntersecting && !terminal.dataset.started) {
        terminal.dataset.started = '1';
        wrapper?.classList.add('visible');
        const projectName = terminal.dataset.project!;
        const anim = terminalAnimations[projectName];
        if (!anim) return;
        const titleEl = wrapper?.querySelector('[data-terminal-title]');
        if (titleEl) titleEl.textContent = anim.title;
        loopTerminalAnimation(terminal, anim.lines);
      }
    });
  }, { threshold: 0.3 });

  const previewObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const preview = entry.target as HTMLElement;
      const wrapper = preview.closest('.mini-preview') as HTMLElement;
      if (entry.isIntersecting && !preview.dataset.started) {
        preview.dataset.started = '1';
        wrapper?.classList.add('visible');
        const projectName = preview.dataset.project!;
        if (projectName === 'Personal Dietician') {
          loopUIMockup(preview, buildDieticianMockup);
        } else if (projectName === 'DrinkFinder') {
          loopUIMockup(preview, buildDrinkFinderMockup);
        }
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.terminal-body').forEach(el => terminalObserver.observe(el));
  document.querySelectorAll('.preview-body').forEach(el => previewObserver.observe(el));
</script>
